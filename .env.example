# ============================================================
# Mories Configuration — .env.example
# ============================================================
# Copy this file to .env and adjust values for your environment.
# 
# Deployment modes:
#   AIRGAP (default) — Neo4j + local Inference Server (Ollama/vLLM)
#   CLOUD            — Neo4j + Supermemory (hybrid storage)
# ============================================================

# --- Storage ---
# Options: "neo4j" (airgap, default) or "hybrid" (Neo4j + Supermemory)
STORAGE_BACKEND=neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=mirofish

# --- Supermemory (CLOUD mode only) ---
# Leave empty or omit entirely for airgap deployments.
# The system works 100% without Supermemory using Neo4j as Source of Truth.
# SUPERMEMORY_API_KEY=your-supermemory-api-key-here

# --- LLM (Air-Gap Inference Server) ---
# LLM_PROVIDER: openai | ollama | vllm
LLM_PROVIDER=ollama
LLM_API_KEY=ollama
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL_NAME=qwen2.5:32b
OLLAMA_NUM_CTX=8192

# --- Embedding ---
# Ollama:    EMBEDDING_BASE_URL=http://localhost:11434
# vLLM:      EMBEDDING_BASE_URL=http://your-vllm-host:8000
# Provider auto-detection: "ollama" for port 11434, "openai" for others
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_BASE_URL=http://localhost:11434
# EMBEDDING_PROVIDER=auto
# EMBEDDING_API_KEY=  (not needed for Ollama)

# --- Data Ingestion ---
CSV_ROW_LIMIT=10000
STREAM_ENABLED=false
ALLOWED_EXTENSIONS=pdf,md,txt,docx,html,xlsx,csv,json,jsonl,parquet,yaml,yml

# --- Security / Harness ---
# MCP API key for multi-agent access control (leave empty to disable)
MCP_API_KEY=
# HMAC-SHA256 secret for webhook signature verification
WEBHOOK_SECRET=your-webhook-hmac-secret
POSTGRES_ALLOWED_TABLES=agents,posts,comments,likes

# --- Harness: Webhooks (Harness Architecture Phase G) ---
# Set true to publish events to external orchestration (n8n, Dify)
WEBHOOK_ENABLED=false
# Comma-separated receiver URLs
# WEBHOOK_URL=http://n8n:5678/webhook/mories-events
WEBHOOK_TIMEOUT=5

# --- Flask ---
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_SECRET_KEY=change-me-in-production
