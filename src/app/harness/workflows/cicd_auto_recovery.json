{
  "harness_id": "cicd_auto_recovery",
  "version": 1,
  "domain": "devops_automation",
  "description": "CI/CD 자동 복구: PR 이벤트 수신 → 빌드 → 테스트 → 실패 시 LLM 분석/패치 → 재빌드(최대2회) → 스테이징 배포 or 슬랙 알림",
  "env": {
    "DIFY_BASE_URL": "http://100.75.95.45:5001/v1",
    "SLACK_WEBHOOK": "https://hooks.slack.com/services/sim"
  },
  "steps": [
    {
      "id": "pr_event",
      "type": "code",
      "description": "GitHub PR merge 이벤트 수신",
      "action": "scenario_helpers.receive_pr_event",
      "params": {"repo": "mirofish/supermemory"},
      "output_key": "event"
    },
    {
      "id": "build",
      "type": "code",
      "description": "빌드 실행",
      "action": "scenario_helpers.run_build",
      "params": {"commit_sha": "${pr_event.event}"},
      "output_key": "build_result",
      "on_error": "skip"
    },
    {
      "id": "check_build",
      "type": "branch",
      "description": "빌드 성공 여부 판단",
      "condition": "${build.build_result} != null",
      "then": "run_tests",
      "else": "analyze_error"
    },
    {
      "id": "run_tests",
      "type": "code",
      "description": "테스트 실행",
      "action": "scenario_helpers.run_tests",
      "params": {"build_success": true},
      "output_key": "test_result"
    },
    {
      "id": "check_tests",
      "type": "branch",
      "description": "테스트 성공 시 배포, 실패 시 에러 분석",
      "condition": "${run_tests.test_result} != null",
      "then": "deploy",
      "else": "analyze_error"
    },
    {
      "id": "analyze_error",
      "type": "code",
      "description": "LLM으로 에러 로그 분석 및 자동 패치 생성",
      "action": "scenario_helpers.analyze_error_with_llm",
      "params": {"error_log": "build or test failure"},
      "output_key": "analysis"
    },
    {
      "id": "rebuild_loop",
      "type": "loop",
      "description": "패치 적용 후 재빌드 (최대 2회)",
      "max_iterations": 2,
      "goto": "build"
    },
    {
      "id": "deploy",
      "type": "code",
      "description": "스테이징 환경에 배포",
      "action": "scenario_helpers.deploy_to_staging",
      "params": {"commit_sha": "${pr_event.event}"},
      "output_key": "deploy_result"
    },
    {
      "id": "notify_success",
      "type": "code",
      "description": "배포 성공 알림",
      "action": "scenario_helpers.send_slack_alert",
      "params": {"message": "스테이징 배포 성공!", "channel": "#devops"},
      "output_key": "notification"
    },
    {
      "id": "complete",
      "type": "end",
      "description": "CI/CD 파이프라인 완료"
    }
  ],
  "state_storage": {"type": "json_file", "path": "./harness_state"},
  "monitoring": {
    "webhook_on_failure": "http://100.75.95.45:5678/webhook/harness-fail",
    "log_level": "INFO"
  }
}
